# ───────────────────────────────────────────────────────────────
# Guia completo de deploy e descrição de cada variável: DEPLOY_VERCEL.md
# ───────────────────────────────────────────────────────────────

# Banco (injetadas pela integração de Postgres do Vercel Marketplace)
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# App
API_ACCESS_TOKEN=        # auth de todas as rotas /api/* (proxy.ts)
CRON_SECRET=             # auth do cron de webhooks; o Vercel injeta como Bearer

# Não lidas pelo código atual (ver DEPLOY_VERCEL.md §3):
# ENCRYPTION_KEY        — planejada p/ criptografar secret de webhook; não implementada
# CUSTOMER_LOOKUP_URL   — URL de lookup é configurada pela UI (app_settings), não por env
ENCRYPTION_KEY=
CUSTOMER_LOOKUP_URL=
