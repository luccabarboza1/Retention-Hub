APP_NAME="Retention Hub"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://revops.umbler-tasks.com

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=retention_hub
