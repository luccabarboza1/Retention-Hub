DB_PASSWORD=

QUEUE_CONNECTION=database

# Token estático para autenticação da API pública
API_ACCESS_TOKEN=

# Timeout (em segundos) para chamadas HTTP de webhook outbound
WEBHOOK_HTTP_TIMEOUT=25

MAIL_MAILER=log
